rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Check if user is an admin by querying Firestore
    function isAdmin() {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /products/{productId}/{filename} {
      // public read for everything except zip
      allow read: if filename != 'download.zip';
      
      // download.zip only if purchased
      allow read: if request.auth != null && filename == 'download.zip' &&
        firestore.exists(/databases/(default)/documents/userPurchases/$(request.auth.uid)/products/$(productId));
        
      allow write: if isAdmin();
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
